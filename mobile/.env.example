# Base URL of the TaskBuddy NestJS backend the mobile app talks to.
#
# Leave unset to use the deployed backend (https://taskbuddy-1d48.onrender.com).
#
# To run against a backend on your own machine, set this to your computer's
# LAN IP (NOT localhost — the phone/emulator can't reach the dev machine's
# localhost). Find it with `ipconfig` (Windows) / `ifconfig` (macOS/Linux):
#
#   EXPO_PUBLIC_API_URL=http://192.168.1.20:3000
#
# Only EXPO_PUBLIC_* variables are exposed to the app at build time.
EXPO_PUBLIC_API_URL=
